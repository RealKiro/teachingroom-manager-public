# ============================================================
#  TeachingRoom Manager — 环境变量模板
#  用法：复制此文件为 .env，然后编辑
#  注意：.env 文件中的变量会被 docker compose 自动读取
# ============================================================

# ── 必填 ──────────────────────────────────────────────────
# Session 加密密钥（生成建议：openssl rand -hex 32）
SESSION_SECRET=

# ── 数据库 ─────────────────────────────────────────────────
# 默认使用 SQLite（无需额外配置，零依赖）
#
# 若要使用 MySQL / MariaDB（需 npm install mysql2）：
# DATABASE_URL="mysql://user:password@host:3306/dbname"
# 或
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=teachingroom
#
# 若要使用 PostgreSQL（需 npm install pg）：
# DATABASE_URL="postgres://user:password@host:5432/dbname"
# 或
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=teachingroom
#
# SQLite 数据库路径（仅 SQLite 模式有效）
# DB_PATH=./data/teachingroom.sqlite

# ── 可选 ──────────────────────────────────────────────────
# 首次启动的管理员密码（至少 12 位；留空则自动生成到 data/initial-admin-password.txt）
# INITIAL_ADMIN_PASSWORD=

# 基础数据 API 的 CORS 白名单（留空则不开放跨域，多个来源用逗号分隔）
# BASE_DATA_CORS_ORIGIN=

# 备份镜像目录（同步到第二块磁盘或网络目录）
# BACKUP_MIRROR_DIR=
